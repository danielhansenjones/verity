POSTGRES_USER=contractuser
POSTGRES_PASSWORD=contractpass
POSTGRES_DB=contractdb
POSTGRES_HOST=localhost

REDIS_HOST=localhost

# Redis Streams queue: group name and the idle threshold before XAUTOCLAIM reclaims a stale entry.
JOB_QUEUE_GROUP=workers
JOB_QUEUE_IDLE_MS=60000

MINIO_HOST=localhost
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=contracts

# API auth. Leave unset for local dev (auth disabled, warning logged at startup).
# Must be set in any non-dev deployment.
CONTRACT_API_KEY=

# Cap on POST /jobs request body in bytes. Defaults to 25 MiB.
MAX_UPLOAD_BYTES=26214400

# Per-IP rate limits. slowapi syntax: "<count>/<period>".
RATE_LIMIT_SUBMIT=30/minute
RATE_LIMIT_READ=120/minute

# Port for the worker /metrics endpoint. API metrics ride on the API port.
WORKER_METRICS_PORT=9100

# v2 cascade: span extractor.
# Default model is roberta-base (faster, 0.73 trimmed F1).
# Swap to roberta_large_squad2_cuad for higher accuracy (0.75 trimmed F1, ~2x slower).
SPAN_EXTRACTOR_ENABLED=false
SPAN_EXTRACTOR_MODEL_PATH=./cuad/artifacts/models/roberta_base_squad2_cuad
SPAN_EXTRACTOR_TIER1_CONFIDENCE_THRESHOLD=0.7
# Per-chunk timeout for tier-2 inference. Exceeded timeout skips extraction and keeps the tier-1 label.
SPAN_EXTRACTOR_TIMEOUT_S=30
