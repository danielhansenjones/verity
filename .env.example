POSTGRES_USER=contractuser
POSTGRES_PASSWORD=contractpass
POSTGRES_DB=contractdb
POSTGRES_HOST=localhost

REDIS_HOST=localhost

MINIO_HOST=localhost
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=contracts

# API auth. Leave unset for local dev (auth disabled, warning logged at startup).
# Must be set in any non-dev deployment.
CONTRACT_API_KEY=

# Cap on POST /jobs request body in bytes. Defaults to 25 MiB.
MAX_UPLOAD_BYTES=26214400

# Per-IP rate limits. slowapi syntax: "<count>/<period>".
RATE_LIMIT_SUBMIT=30/minute
RATE_LIMIT_READ=120/minute

# Port for the worker /metrics endpoint. API metrics ride on the API port.
WORKER_METRICS_PORT=9100
